{
  "version": 1,
  "hooks": {
    "sessionStart": [ { "command": "node \"${CURSOR_PLUGIN_ROOT}/scripts/cursor-hook-bootstrap.mjs\"" } ],
    "beforeSubmitPrompt": [ { "command": "node \"${CURSOR_PLUGIN_ROOT}/scripts/cursor-hook-bootstrap.mjs\"" } ],
    "preToolUse": [
      {
        "command": "node \"${CURSOR_PLUGIN_ROOT}/scripts/cursor-hook-bootstrap.mjs\"",
        "matcher": "Read|Write|Grep|Glob|Task|WebFetch|WebSearch|Shell"
      }
    ],
    "postToolUse": [
      {
        "command": "node \"${CURSOR_PLUGIN_ROOT}/scripts/cursor-hook-bootstrap.mjs\"",
        "matcher": "*"
      }
    ],
    "postToolUseFailure": [ { "command": "node \"${CURSOR_PLUGIN_ROOT}/scripts/cursor-hook-bootstrap.mjs\"" } ],
    "afterFileEdit": [ { "command": "node \"${CURSOR_PLUGIN_ROOT}/scripts/cursor-hook-bootstrap.mjs\"" } ],
    "afterShellExecution": [ { "command": "node \"${CURSOR_PLUGIN_ROOT}/scripts/cursor-hook-bootstrap.mjs\"" } ],
    "afterMCPExecution": [ { "command": "node \"${CURSOR_PLUGIN_ROOT}/scripts/cursor-hook-bootstrap.mjs\"" } ],
    "preCompact": [ { "command": "node \"${CURSOR_PLUGIN_ROOT}/scripts/cursor-hook-bootstrap.mjs\"" } ],
    "subagentStart": [ { "command": "node \"${CURSOR_PLUGIN_ROOT}/scripts/cursor-hook-bootstrap.mjs\"" } ],
    "subagentStop": [ { "command": "node \"${CURSOR_PLUGIN_ROOT}/scripts/cursor-hook-bootstrap.mjs\"" } ],
    "stop": [ { "command": "node \"${CURSOR_PLUGIN_ROOT}/scripts/cursor-hook-bootstrap.mjs\"" } ],
    "sessionEnd": [ { "command": "node \"${CURSOR_PLUGIN_ROOT}/scripts/cursor-hook-bootstrap.mjs\"" } ]
  }
}
